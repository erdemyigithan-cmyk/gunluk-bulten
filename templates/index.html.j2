{% extends "base.html.j2" %}
{% block title %}Günlük Bülten Sentezi{% endblock %}
{% block content %}
  <header class="site">
    <h1>Günlük Bülten Sentezi</h1>
    <span class="sub">{{ gunler|length }} gün arşivde</span>
  </header>
  {% if not gunler %}
    <p class="empty">Henüz bülten yok.</p>
  {% else %}
    {% for g in gunler %}
      <div class="idx-row">
        <div>
          <a class="tarih" href="{{ g.dosya }}">{{ g.tarih }}</a>
          <span class="meta">{{ g.kaynak_sayisi }} kaynak{% if g.eksik_sayisi %} · {{ g.eksik_sayisi }} eksik{% endif %}</span>
        </div>
        {% if g.ozet %}<div class="ozet">{{ g.ozet }}</div>{% endif %}
      </div>
    {% endfor %}
  {% endif %}
{% endblock %}
