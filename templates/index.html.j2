{% extends "base.html.j2" %}
{% block title %}Günlük Bülten Sentezi{% endblock %}
{% block content %}
  <header class="site">
    <h1>Günlük Bülten Sentezi</h1>
    <span class="sub">{{ gunler|length }} gün arşivde</span>
  </header>

  <div class="kontrol">
    <button id="yenile-btn" onclick="yenile()">⟳ Bugünü Oluştur / Yenile</button>
    <span id="durum-yazi" class="durum"></span>
  </div>

  {% if not gunler %}
    <p class="empty">Henüz bülten yok. Yukarıdaki düğmeyle bugünün bültenini oluştur.</p>
  {% else %}
    {% for g in gunler %}
      <div class="idx-row">
        <div>
          <a class="tarih" href="{{ g.dosya }}">{{ g.tarih }}</a>
          <span class="meta">{{ g.kaynak_sayisi }} kaynak{% if g.eksik_sayisi %} · {{ g.eksik_sayisi }} eksik{% endif %}</span>
        </div>
        {% if g.ozet %}<div class="ozet">{{ g.ozet }}</div>{% endif %}
      </div>
    {% endfor %}
  {% endif %}

  <script>
    async function yenile() {
      const btn = document.getElementById('yenile-btn');
      const yazi = document.getElementById('durum-yazi');
      btn.disabled = true;
      yazi.className = 'durum calisiyor';
      yazi.textContent = 'Bülten oluşturuluyor… (Opus tüm kaynakları okuyor, 1-3 dk sürebilir)';
      try {
        const r = await fetch('/yenile', { method: 'POST' });
        if (r.status === 409) { yazi.textContent = 'Zaten oluşturuluyor…'; }
        poll();
      } catch (e) {
        btn.disabled = false;
        yazi.className = 'durum hata';
        yazi.textContent = 'Sunucu çalışmıyor. Panoyu "python -m src.server" ile başlat.';
      }
    }
    async function poll() {
      try {
        const d = await (await fetch('/durum')).json();
        if (d.calisiyor) { setTimeout(poll, 3000); return; }
        const btn = document.getElementById('yenile-btn');
        const yazi = document.getElementById('durum-yazi');
        btn.disabled = false;
        if (d.hata) { yazi.className = 'durum hata'; yazi.textContent = 'Hata: ' + d.hata; }
        else { location.reload(); }
      } catch (e) { setTimeout(poll, 3000); }
    }
  </script>
{% endblock %}
