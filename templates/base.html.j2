<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}Günlük Bülten{% endblock %}</title>
<style>
  :root {
    --bg: #0f1115; --panel: #171a21; --border: #272c38;
    --text: #e6e8ee; --muted: #99a0b0; --accent: #4f8cff;
    --pos: #2fbf71; --neg: #e5484d;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0; background: var(--bg); color: var(--text);
    font: 16px/1.7 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  .wrap { max-width: 820px; margin: 0 auto; padding: 40px 22px 90px; }
  .topbar { font-size: 13px; color: var(--muted); margin-bottom: 18px; }

  /* Bülten (markdown) prose */
  .bulten h1 {
    font-size: 26px; letter-spacing: -.02em; margin: 0 0 4px;
    border-bottom: 2px solid var(--accent); padding-bottom: 14px;
  }
  .bulten h2 {
    font-size: 14px; text-transform: uppercase; letter-spacing: .09em;
    color: var(--accent); margin: 38px 0 12px;
    border-top: 1px solid var(--border); padding-top: 20px;
  }
  .bulten h3 { font-size: 16px; margin: 20px 0 6px; }
  .bulten p, .bulten li { color: #d7dbe6; }
  .bulten strong { color: #fff; }
  .bulten em { color: var(--muted); }
  .bulten hr { border: none; border-top: 1px solid var(--border); margin: 26px 0; }
  .bulten code { background: var(--panel); padding: 1px 5px; border-radius: 4px; }
  .bulten ul { padding-left: 22px; }
  .bulten li { margin: 5px 0; }
  .bulten table { border-collapse: collapse; width: 100%; margin: 12px 0; font-size: 14px; }
  .bulten th, .bulten td { border: 1px solid var(--border); padding: 6px 10px; text-align: left; }
  .bulten th { background: var(--panel); }

  /* Index */
  header.site {
    border-bottom: 1px solid var(--border); padding-bottom: 16px; margin-bottom: 24px;
    display: flex; align-items: baseline; justify-content: space-between; gap: 12px;
  }
  header.site h1 { font-size: 22px; margin: 0; }
  header.site .sub { color: var(--muted); font-size: 13px; }
  .kontrol { display: flex; align-items: center; gap: 14px; margin-bottom: 22px; flex-wrap: wrap; }
  #yenile-btn {
    background: var(--accent); color: #fff; border: none; border-radius: 8px;
    padding: 10px 16px; font-size: 14px; font-weight: 600; cursor: pointer;
  }
  #yenile-btn:hover { filter: brightness(1.08); }
  #yenile-btn:disabled { opacity: .55; cursor: default; }
  .durum { font-size: 13px; color: var(--muted); }
  .durum.calisiyor { color: var(--accent); }
  .durum.hata { color: var(--neg); }
  .idx-row { padding: 16px 0; border-bottom: 1px solid var(--border); }
  .idx-row .tarih { font-weight: 700; font-size: 17px; }
  .idx-row .meta { font-size: 12px; color: var(--muted); margin-left: 10px; }
  .idx-row .ozet { color: var(--muted); margin-top: 4px; }
  .empty { color: var(--muted); font-style: italic; }
</style>
</head>
<body>
<div class="wrap">
  {% block content %}{% endblock %}
</div>
</body>
</html>
